# --- 基础设置 ---
set $mod Mod1
# 字体设大一点 (窗口标题栏字体)
font pango:DejaVu Sans Mono 16

# --- 核心功能键 ---
# 终端
bindsym $mod+Return exec alacritty

# 杀窗口
bindsym $mod+Shift+q kill

# --- 新增：软件快捷键 ---
# 浏览器 (Alt + W)
bindsym $mod+w exec firefox

# 文件管理器 (Alt + F)
bindsym $mod+f exec thunar

# 漂亮的启动菜单 (Alt + D) - 替换掉原来的 dmenu
# -show drun: 显示应用列表
# -font: 设置菜单字体大小
bindsym $mod+d exec rofi -show drun -font "DejaVu Sans Mono 20" -show-icons

# --- 视觉装修 ---
# 1. 加载 DPI 设置 (解决字体太小)
exec --no-startup-id xrdb -merge ~/.Xresources

# 2. 设置壁纸
exec_always --no-startup-id feh --bg-fill /root/sdcard/Pictures/Wallpapers/Twin.jpg

# 3. 去掉丑陋的标题栏，改用像素边框
# 恢复标题栏 (normal 2 代表标题栏高度适应字体，边框2像素)
default_border normal 2
default_floating_border normal 2

font pango:DejaVu Sans Mono 10

# 4. 窗口颜色美化 (Arc Dark 风格配色)
# class                 border  backgr. text    indicator child_border
client.focused          #5294e2 #5294e2 #ffffff #2e9ef4   #5294e2
client.focused_inactive #333333 #5f676a #ffffff #484e50   #5f676a
client.unfocused        #333333 #222222 #888888 #292d2e   #222222
client.urgent           #2f343a #900000 #ffffff #900000   #900000

# --- 窗口操作 ---
floating_modifier $mod
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right
bindsym $mod+h split h
bindsym $mod+v split v
bindsym $mod+s layout stacking
bindsym $mod+e layout toggle split
bindsym $mod+t floating toggle
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Exit?' -B 'Yes' 'i3-msg exit'"

# --- 状态栏 (字体调大) ---
bar {
        status_command i3status
        position top
        font pango:DejaVu Sans Mono 16
        colors {
            background #1c1c1c
            statusline #dddddd
            separator #666666
            focused_workspace  #0088CC #0088CC #ffffff
            active_workspace   #333333 #333333 #ffffff
            inactive_workspace #333333 #333333 #888888
            urgent_workspace   #2f343a #900000 #ffffff
        }
}
