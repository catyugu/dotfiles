# --- Fcitx5 & D-Bus Shared Session Setup ---

# 1. Set Runtime Directory
if [ -z "$XDG_RUNTIME_DIR" ]; then
  export XDG_RUNTIME_DIR=/tmp/$(id -u)-runtime-dir
  if [ ! -d "$XDG_RUNTIME_DIR" ]; then
    mkdir -p $XDG_RUNTIME_DIR
    chmod 0700 $XDG_RUNTIME_DIR
  fi
fi

# 2. SHARED D-Bus Setup (The Fix)
# We store the address in a file so all apps use the SAME bus.
DBUS_SESSION_FILE="$XDG_RUNTIME_DIR/dbus-session"

if [ -f "$DBUS_SESSION_FILE" ]; then
  source "$DBUS_SESSION_FILE"
fi

# Check if the saved DBus is actually alive. If not, start a new one.
if [ -z "$DBUS_SESSION_BUS_ADDRESS" ] || ! dbus-send --print-reply --dest=org.freedesktop.DBus /org/freedesktop/DBus org.freedesktop.DBus.Peer.Ping >/dev/null 2>&1; then
  eval $(dbus-launch --sh-syntax)
  echo "export DBUS_SESSION_BUS_ADDRESS='$DBUS_SESSION_BUS_ADDRESS'" >"$DBUS_SESSION_FILE"
  echo "export DBUS_SESSION_BUS_PID='$DBUS_SESSION_BUS_PID'" >>"$DBUS_SESSION_FILE"
fi

# 3. Export Variables
export GTK_IM_MODULE=fcitx
export QT_IM_MODULE=fcitx
export XMODIFIERS=@im=fcitx
export SDL_IM_MODULE=fcitx
export GLFW_IM_MODULE=ibus

# 4. Start Fcitx5 (only if not running)
if ! pgrep -x "fcitx5" >/dev/null; then
  fcitx5 -d >/dev/null 2>&1 &
fi
