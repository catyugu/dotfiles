# =============================================================================
# .rc — alias、自定义函数、提示符等（可重载）
# =============================================================================

# Git dotfile 管理别名
alias ls='ls --color=auto'
alias grep='grep --color=auto'

alias config='git --git-dir=$HOME/dotfiles/.git --work-tree=$HOME'

# ---------------------------------------------------------------------
# 添加更多 alias / 函数 / 提示符到这里
# ---------------------------------------------------------------------

# 示例：
# alias ll='ls -la'
# alias gs='git status'
# PS1='...'
